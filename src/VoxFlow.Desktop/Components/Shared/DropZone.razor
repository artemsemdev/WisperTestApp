<div class="drop-zone @(_isDragOver ? "drag-over" : "")"
     @ondragenter="HandleDragEnter"
     @ondragover="HandleDragOver"
     @ondragover:preventDefault
     @ondragleave="HandleDragLeave"
     @ondrop="HandleDrop"
     @ondrop:preventDefault>

    <span class="drop-icon">\uD83C\uDFA4</span>
    <span class="drop-label">@(Label ?? "Drop audio file here")</span>
    <span class="drop-hint">Supports M4A, WAV, MP3, and other audio formats</span>
</div>

@code {
    [Parameter]
    public EventCallback<string> OnFileSelected { get; set; }

    [Parameter]
    public string? Label { get; set; }

    private bool _isDragOver;

    private void HandleDragEnter()
    {
        _isDragOver = true;
    }

    private void HandleDragOver()
    {
        // Keep drag-over state active; preventDefault handled via directive
    }

    private void HandleDragLeave()
    {
        _isDragOver = false;
    }

    private async Task HandleDrop()
    {
        _isDragOver = false;

        // File path extraction requires JS interop which will be wired in Task 17.
        // For now, invoke the callback with a placeholder to validate the wiring.
        // The JS interop layer will call OnFileSelected with the actual file path.
        await Task.CompletedTask;
    }
}
