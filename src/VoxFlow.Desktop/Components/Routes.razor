@using System.ComponentModel
@implements IDisposable
@inject AppViewModel ViewModel

@if (!string.IsNullOrWhiteSpace(_startupError))
{
    <div class="text-center" id="startup-error-screen" aria-label="Startup Error Screen">
        <h2>Startup Failed</h2>
        <p class="text-secondary mt-2">@_startupError</p>
    </div>

    <div class="btn-group mt-6">
        <button id="startup-retry-button"
                class="btn btn-primary btn-sm"
                aria-label="Retry Startup"
                title="Retry Startup"
                @onclick="RetryInitializationAsync">
            Retry
        </button>
    </div>
}
else
{
    <MainLayout />
}

@code {
    private string? _startupError;

    protected override async Task OnInitializedAsync()
    {
        ViewModel.PropertyChanged += HandleViewModelChanged;
        await InitializeViewModelAsync();
    }

    private async Task RetryInitializationAsync()
    {
        await InitializeViewModelAsync();
    }

    private async Task InitializeViewModelAsync()
    {
        _startupError = null;

        try
        {
            await ViewModel.InitializeAsync();
        }
        catch (Exception ex)
        {
            _startupError = ex.Message;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void HandleViewModelChanged(object? sender, PropertyChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= HandleViewModelChanged;
    }
}
