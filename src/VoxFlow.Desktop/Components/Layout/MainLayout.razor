@inherits LayoutComponentBase
@inject AppViewModel ViewModel

<div class="app-shell">
    <main class="app-content">
        @switch (ViewModel.CurrentState)
        {
            case AppState.Ready:
                <ReadyView />
                break;
            case AppState.Running:
                <RunningView />
                break;
            case AppState.Failed:
                <FailedView />
                break;
            case AppState.Complete:
                <CompleteView />
                break;
        }
    </main>
</div>
