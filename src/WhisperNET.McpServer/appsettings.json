{
  "mcp": {
    "enabled": true,
    "transport": "stdio",
    "serverName": "whispernet",
    "serverVersion": "1.0.0",
    "allowBatch": true,
    "allowedInputRoots": [],
    "allowedOutputRoots": [],
    "maxBatchFiles": 100,
    "requireAbsolutePaths": true,
    "resources": {
      "enabled": true,
      "exposeLastRun": true
    },
    "prompts": {
      "enabled": true
    },
    "logging": {
      "minimumLevel": "Information",
      "writeToStdErr": true,
      "writeToFile": false,
      "logFilePath": ""
    }
  }
}
